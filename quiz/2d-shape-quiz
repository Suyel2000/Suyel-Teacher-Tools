<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🔷 2D Shapes Quiz</title>
    <style>
        :root {
            --primary: #4a90e2;
            --secondary: #f5a623;
            --success: #2ecc71;
            --danger: #e74c3c;
            --bg-grad-1: #1a2a6c;
            --bg-grad-2: #b21f1f;
            --bg-grad-3: #fdbb2d;
            --card-bg: rgba(255, 255, 255, 0.92);
            --text-main: #2c3e50;
            --text-muted: #7f8c8d;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            min-height: 100vh;
            background: linear-gradient(135deg, var(--bg-grad-1), var(--bg-grad-2), var(--bg-grad-3));
            background-size: 400% 400%;
            animation: gradientBg 20s ease infinite;
            display: flex;
            flex-direction: column;
            align-items: center;
            overflow-x: hidden;
            padding: 20px 10px;
        }

        @keyframes gradientBg {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        .bg-shapes {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            pointer-events: none;
            overflow: hidden;
        }

        .bg-shape {
            position: absolute;
            opacity: 0.15;
            animation: floatShape 15s linear infinite;
        }

        @keyframes floatShape {
            0% { transform: translateY(110vh) rotate(0deg); }
            100% { transform: translateY(-20vh) rotate(360deg); }
        }

        .container {
            width: 100%;
            max-width: 850px;
            margin-bottom: 30px;
        }

        header {
            background: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.25);
            border-radius: 20px;
            padding: 25px;
            text-align: center;
            color: #ffffff;
            margin-bottom: 25px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
        }

        header h1 {
            font-size: 2.5rem;
            margin-bottom: 5px;
            text-shadow: 0 2px 4px rgba(0,0,0,0.3);
        }

        header p {
            font-size: 1.1rem;
            opacity: 0.9;
            font-weight: 300;
        }

        .tabs {
            display: flex;
            justify-content: center;
            gap: 10px;
            margin-bottom: 20px;
            width: 100%;
            max-width: 850px;
        }

        .tab-btn {
            background: rgba(255, 255, 255, 0.2);
            border: 1px solid rgba(255, 255, 255, 0.2);
            color: white;
            padding: 12px 20px;
            border-radius: 30px;
            cursor: pointer;
            font-size: 1rem;
            font-weight: 600;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }

        .tab-btn:hover, .tab-btn.active {
            background: white;
            color: var(--bg-grad-1);
            transform: translateY(-2px);
        }

        .card {
            background: var(--card-bg);
            border-radius: 24px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.15);
            padding: 30px;
            width: 100%;
            display: none;
            animation: fadeIn 0.4s ease-out forwards;
        }

        .card.active {
            display: block;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(15px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .btn {
            padding: 14px 28px;
            border: none;
            border-radius: 16px;
            cursor: pointer;
            font-weight: 700;
            font-size: 1.05rem;
            transition: all 0.2s ease;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .btn:active { transform: scale(0.97); }
        .btn-primary { background: var(--primary); color: white; }
        .btn-primary:hover { background: #357abd; }
        .btn-secondary { background: #7f8c8d; color: white; }
        .btn-secondary:hover { background: #6c7a7d; }

        .quiz-meta {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            font-size: 1.05rem;
            font-weight: 600;
            color: var(--text-main);
        }

        .progress-container {
            width: 100%;
            height: 12px;
            background: #e0e0e0;
            border-radius: 6px;
            overflow: hidden;
            margin-bottom: 25px;
        }

        .progress-bar {
            width: 0%;
            height: 100%;
            background: linear-gradient(90deg, #3498db, #2ecc71);
            transition: width 0.3s ease;
        }

        .question-box h2 {
            color: var(--text-main);
            font-size: 1.4rem;
            margin-bottom: 20px;
            line-height: 1.4;
        }

        /* Fixed Shape Container: Medium Sizing */
        .visual-display {
            display: flex;
            justify-content: center;
            align-items: center;
            height: 150px;
            width: 100%;
            margin: 0 auto 25px auto;
            background: #f8f9fa;
            border-radius: 16px;
            border: 2px dashed #e2e8f0;
            padding: 10px;
        }

        .visual-display svg {
            max-width: 130px;
            max-height: 130px;
            width: 100%;
            height: 100%;
        }

        .options-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 15px;
            margin-bottom: 25px;
        }

        @media (max-width: 600px) {
            .options-grid { grid-template-columns: 1fr; }
            header h1 { font-size: 1.8rem; }
            .tabs { flex-wrap: wrap; }
            .tab-btn { flex: 1 1 40%; text-align: center; font-size: 0.9rem;}
        }

        .option-btn {
            background: #ffffff;
            border: 3px solid #e2e8f0;
            border-radius: 16px;
            padding: 18px;
            font-size: 1.1rem;
            font-weight: 600;
            color: var(--text-main);
            cursor: pointer;
            transition: all 0.2s ease;
            text-align: left;
            box-shadow: 0 4px 6px rgba(0,0,0,0.02);
        }

        .option-btn:hover {
            border-color: var(--primary);
            background: #f4f8fd;
            transform: translateY(-2px);
        }

        .option-btn.correct {
            background: #e8f8f0 !important;
            border-color: var(--success) !important;
            color: #1e7e34 !important;
        }

        .option-btn.wrong {
            background: #fceade !important;
            border-color: var(--danger) !important;
            color: #bd2130 !important;
        }

        .option-btn.disabled {
            pointer-events: none;
            opacity: 0.6;
        }
        .option-btn.disabled.correct, .option-btn.disabled.wrong { opacity: 1; }

        .feedback-box {
            display: none;
            padding: 20px;
            border-radius: 16px;
            margin-bottom: 25px;
            font-size: 1.05rem;
            line-height: 1.5;
            animation: fadeIn 0.3s ease;
        }

        .feedback-box.correct { display: block; background: #e8f8f0; border-left: 6px solid var(--success); color: #1e7e34; }
        .feedback-box.wrong { display: block; background: #fceade; border-left: 6px solid var(--danger); color: #bd2130; }

        .quiz-controls {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .results-container {
            text-align: center;
            padding: 20px 0;
        }

        .badge-display {
            margin: 20px auto;
            width: 140px;
            height: 140px;
            border-radius: 50%;
            background: #fff;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            font-size: 3rem;
            border: 4px solid var(--secondary);
            animation: bounce 1s alternate infinite;
        }

        @keyframes bounce {
            from { transform: translateY(0); }
            to { transform: translateY(-8px); }
        }

        .badge-title {
            font-size: 1.4rem;
            font-weight: 700;
            color: var(--text-main);
            margin-bottom: 10px;
        }

        .cert-wrap {
            display: none;
            margin-top: 30px;
        }

        .certificate {
            background: #fff;
            border: 10px double #4a90e2;
            padding: 30px;
            position: relative;
            text-align: center;
            color: #333;
            box-shadow: 0 0 20px rgba(0,0,0,0.1);
        }

        .certificate h2 { font-family: 'Georgia', serif; font-size: 2.2rem; color: #2c3e50; }
        .certificate p { margin: 12px 0; font-size: 1.1rem; }
        .certificate .student-name { font-size: 1.8rem; font-weight: bold; text-decoration: underline; color: #34495e; min-width: 200px; display: inline-block; border-bottom: 2px solid #ccc; padding: 5px;}

        .explorer-layout {
            display: flex;
            gap: 20px;
        }

        .shape-sidebar {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 8px;
            max-height: 420px;
            overflow-y: auto;
            padding-right: 5px;
        }

        .shape-sidebar-btn {
            background: #fff;
            border: 2px solid #e2e8f0;
            border-radius: 12px;
            padding: 10px;
            cursor: pointer;
            font-weight: 600;
            text-align: left;
            transition: all 0.2s;
        }

        .shape-sidebar-btn:hover, .shape-sidebar-btn.active {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
        }

        .explorer-workspace {
            flex: 2;
            background: #f8f9fa;
            border-radius: 18px;
            padding: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: space-between;
            min-height: 420px;
        }

        /* Fixed Explorer Canvas: Medium Sizing */
        .explorer-canvas-box {
            width: 100%;
            height: 200px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            background: #ffffff;
            border-radius: 12px;
            border: 1px solid #e2e8f0;
            overflow: hidden;
        }

        .explorer-canvas-box svg {
            max-width: 130px;
            max-height: 130px;
            width: 100%;
            height: 100%;
            transition: transform 0.1s linear;
        }

        .explorer-controls {
            width: 100%;
            display: flex;
            flex-direction: column;
            gap: 10px;
            margin-top: 15px;
        }

        .control-row {
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 600;
            color: var(--text-main);
        }

        .control-row input[type="range"] {
            flex: 1;
        }

        .shape-info-panel {
            width: 100%;
            background: #eef3f9;
            border-radius: 12px;
            padding: 12px;
            font-size: 0.95rem;
            color: var(--text-main);
        }

        @media (max-width: 650px) {
            .explorer-layout { flex-direction: column; }
            .shape-sidebar { flex-direction: row; max-height: unset; overflow-x: auto; padding-bottom: 5px;}
            .shape-sidebar-btn { white-space: nowrap; }
        }

        .sorting-bins {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 15px;
            margin-top: 20px;
        }

        .bin {
            background: #f1f5f9;
            border: 3px dashed #cbd5e1;
            border-radius: 16px;
            padding: 15px;
            min-height: 140px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
            transition: all 0.2s;
        }

        .bin.drag-over {
            background: #e0f2fe;
            border-color: var(--primary);
        }

        .bin h3 {
            font-size: 1rem;
            color: var(--text-main);
            margin-bottom: 5px;
            pointer-events: none;
        }

        .sortable-shapes-pool {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            background: #fff;
            padding: 15px;
            border-radius: 16px;
            border: 1px solid #e2e8f0;
            min-height: 80px;
            justify-content: center;
            align-items: center;
            margin-bottom: 20px;
        }

        .draggable-shape {
            background: #fff;
            border: 2px solid #94a3b8;
            border-radius: 12px;
            padding: 8px 14px;
            cursor: grab;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
            user-select: none;
        }

        .draggable-shape:active { cursor: grabbing; }

        .draggable-shape svg {
            width: 24px;
            height: 24px;
            pointer-events: none;
        }

        #confetti-canvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            z-index: 999;
            pointer-events: none;
            display: none;
        }

        @media print {
            body * { display: none !important; }
            .cert-wrap, .cert-wrap * { display: block !important; }
            .cert-wrap { position: absolute; left: 0; top: 0; width: 100%; box-shadow: none; }
            .print-btn-hide { display: none !important; }
        }
    </style>
</head>
<body>

    <canvas id="confetti-canvas"></canvas>
    <div class="bg-shapes" id="bg-shapes-layer"></div>

    <div class="container">
        <header>
            <h1>🔷 2D Shapes Quiz</h1>
            <p>Learn • Identify • Explore • Master 2D Shapes</p>
        </header>

        <div class="tabs">
            <button class="tab-btn active" onclick="switchTab('quiz-view')">🎮 Play Quiz</button>
            <button class="tab-btn" onclick="switchTab('explorer-view')">🔍 Shape Explorer</button>
            <button class="tab-btn" onclick="switchTab('sorting-view')">🧩 Shape Sorter</button>
        </div>

        <div id="quiz-view" class="card active">
            <div id="quiz-playground">
                <div class="quiz-meta">
                    <span id="question-counter">Question: 1/50</span>
                    <span id="score-counter">Score: 0</span>
                </div>
                <div class="progress-container">
                    <div class="progress-bar" id="quiz-progress"></div>
                </div>

                <div class="question-box">
                    <h2 id="question-text">Loading question text...</h2>
                    <div class="visual-display" id="question-visual"></div>
                    <div class="options-grid" id="options-container"></div>
                </div>

                <div class="feedback-box" id="feedback-panel"></div>

                <div class="quiz-controls">
                    <button class="btn btn-secondary" id="prev-btn" onclick="prevQuestion()" disabled>Previous</button>
                    <button class="btn btn-primary" id="next-btn" onclick="nextQuestion()">Skip</button>
                </div>
            </div>

            <div id="quiz-results" style="display: none;">
                <div class="results-container">
                    <h2>Quiz Completed! 🎉</h2>
                    <p style="font-size: 1.2rem; margin: 10px 0; color: var(--text-main);">Fantastic effort exploring shapes.</p>
                    
                    <div class="badge-display" id="result-badge-icon">🏆</div>
                    <div class="badge-title" id="result-badge-title">Shape Master</div>
                    
                    <p style="font-size: 1.5rem; font-weight: bold; color: var(--primary); margin: 15px 0;" id="final-score-text">Your Score: 0 / 50 (0%)</p>
                    
                    <button class="btn btn-primary" onclick="restartQuiz()">🔄 Play Again</button>
                    <button class="btn btn-secondary" onclick="showCertificateView()" style="background: #9b59b6; margin-left: 10px;">🎓 Get Certificate</button>
                </div>
            </div>
        </div>

        <div id="explorer-view" class="card">
            <h2 style="color: var(--text-main); margin-bottom: 15px;">🔍 Interactive Shape Explorer</h2>
            <p style="color: var(--text-muted); margin-bottom: 20px;">Select any shape to analyze properties, change sizing scales, or apply physical spins.</p>
            
            <div class="explorer-layout">
                <div class="shape-sidebar" id="explorer-menu"></div>
                <div class="explorer-workspace">
                    <div class="explorer-canvas-box">
                        <div id="explorer-svg-container"></div>
                    </div>
                    <div class="explorer-controls">
                        <div class="control-row">
                            <label style="width: 70px;">Scale:</label>
                            <input type="range" id="exp-scale" min="0.5" max="1.5" step="0.1" value="1" oninput="updateExplorerTransform()">
                        </div>
                        <div class="control-row">
                            <label style="width: 70px;">Rotate:</label>
                            <input type="range" id="exp-rotate" min="0" max="360" step="5" value="0" oninput="updateExplorerTransform()">
                        </div>
                    </div>
                    <div class="shape-info-panel" id="explorer-info"></div>
                </div>
            </div>
        </div>

        <div id="sorting-view" class="card">
            <h2 style="color: var(--text-main); margin-bottom: 10px;">🧩 Geometry Drag &amp; Drop Sorter</h2>
            <p style="color: var(--text-muted); margin-bottom: 20px;">Classify the shapes below by dragging them into their corresponding property bins!</p>
            
            <div class="sortable-shapes-pool" id="shapes-drag-pool"></div>

            <div class="sorting-bins">
                <div class="bin" data-criteria="no-sides" ondragover="allowDrop(event)" ondragleave="dragLeave(event)" ondrop="handleDrop(event)">
                    <h3>⭕ No Straight Sides</h3>
                </div>
                <div class="bin" data-criteria="three-sides" ondragover="allowDrop(event)" ondragleave="dragLeave(event)" ondrop="handleDrop(event)">
                    <h3>🔺 3 Sides / Vertices</h3>
                </div>
                <div class="bin" data-criteria="four-sides" ondragover="allowDrop(event)" ondragleave="dragLeave(event)" ondrop="handleDrop(event)">
                    <h3>🟩 4 Sides / Vertices</h3>
                </div>
                <div class="bin" data-criteria="more-sides" ondragover="allowDrop(event)" ondragleave="dragLeave(event)" ondrop="handleDrop(event)">
                    <h3>⬡ More than 4 Sides</h3>
                </div>
            </div>
            
            <div style="text-align: center; margin-top: 25px;">
                <button class="btn btn-primary" onclick="resetSortingActivity()">🔄 Reset Sorting Items</button>
            </div>
        </div>

        <div class="cert-wrap" id="certificate-printout-area">
            <div class="certificate">
                <h2>Certificate of Geometry Excellence</h2>
                <p>This award proudly acknowledges that</p>
                <div class="student-name" contenteditable="true" id="cert-holder-name">Click to Enter Name</div>
                <p>has successfully completed the complete interactive matrix evaluation for</p>
                <h3>🔷 2D Shapes Quiz Module</h3>
                <p style="margin-top: 20px; font-weight: 600;" id="cert-score-metric">Score Attained: 100%</p>
                <p style="font-size: 0.9rem; color: #7f8c8d; margin-top: 25px;">Verified via Native Browser Engine Application</p>
                <div style="margin-top: 20px;" class="print-btn-hide">
                    <button class="btn btn-primary" onclick="window.print()">🖨️ Print Certificate</button>
                    <button class="btn btn-secondary" onclick="document.getElementById('certificate-printout-area').style.display='none'">Close</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        /*****************************************
         * AUDIO CORE (WEB AUDIO API SYNTH)
         *****************************************/
        const AudioEngine = {
            ctx: null,
            init() {
                if (!this.ctx) {
                    this.ctx = new (window.AudioContext || window.webkitAudioContext)();
                }
            },
            playTone(freq, type, duration, vol) {
                this.init();
                try {
                    let osc = this.ctx.createOscillator();
                    let gain = this.ctx.createGain();
                    osc.type = type;
                    osc.frequency.setValueAtTime(freq, this.ctx.currentTime);
                    gain.gain.setValueAtTime(vol, this.ctx.currentTime);
                    gain.gain.exponentialRampToValueAtTime(0.00001, this.ctx.currentTime + duration);
                    osc.connect(gain);
                    gain.connect(this.ctx.destination);
                    osc.start();
                    osc.stop(this.ctx.currentTime + duration);
                } catch(e) { console.log("Audio block/error:", e); }
            },
            click() { this.playTone(600, 'sine', 0.1, 0.2); },
            correct() {
                this.playTone(523.25, 'sine', 0.15, 0.2);
                setTimeout(() => this.playTone(659.25, 'sine', 0.3, 0.2), 120);
            },
            wrong() {
                this.playTone(220, 'sawtooth', 0.2, 0.15);
                setTimeout(() => this.playTone(180, 'sawtooth', 0.25, 0.15), 150);
            },
            badge() {
                let now = 0;
                [440, 554, 659, 880].forEach((f, i) => {
                    setTimeout(() => this.playTone(f, 'triangle', 0.2, 0.25), now);
                    now += 120;
                });
            }
        };

        /*****************************************
         * SHAPES GEOMETRY ENGINE (SVG DEFINITIONS)
         *****************************************/
        const ShapeRegistry = {
            Circle: `<circle cx="100" cy="100" r="75" fill="#3498db" stroke="#2980b9" stroke-width="5" />`,
            Triangle: `<polygon points="100,25 30,165 170,165" fill="#e74c3c" stroke="#c0392b" stroke-width="5" />`,
            Square: `<rect x="35" y="35" width="130" height="130" fill="#2ecc71" stroke="#27ae60" stroke-width="5" />`,
            Rectangle: `<rect x="20" y="50" width="160" height="100" fill="#9b59b6" stroke="#8e44ad" stroke-width="5" />`,
            Oval: `<ellipse cx="100" cy="100" rx="80" ry="52" fill="#f1c40f" stroke="#f39c12" stroke-width="5" />`,
            Pentagon: `<polygon points="100,25 171,77 144,160 56,160 29,77" fill="#1abc9c" stroke="#16a085" stroke-width="5" />`,
            Hexagon: `<polygon points="100,25 165,62 165,138 100,175 35,138 35,62" fill="#e67e22" stroke="#d35400" stroke-width="5" />`,
            Heptagon: `<polygon points="100,22 162,52 181,118 143,172 57,172 19,118 38,52" fill="#34495e" stroke="#2c3e50" stroke-width="5" />`,
            Octagon: `<polygon points="100,20 153,42 175,95 153,148 100,170 47,148 25,95 47,42" fill="#e84393" stroke="#d63031" stroke-width="5" />`,
            Nonagon: `<polygon points="100,20 148,37 177,78 177,129 148,170 100,180 52,170 23,129 23,78 52,37" fill="#6c5ce7" stroke="#4834d4" stroke-width="5" />`,
            Decagon: `<polygon points="100,20 141,33 169,65 178,107 163,148 127,175 73,175 37,148 22,107 31,65 59,33" fill="#00b894" stroke="#006266" stroke-width="5" />`,
            Semicircle: `<path d="M 25,120 A 75,75 0 0,1 175,120 Z" fill="#fdcb6e" stroke="#e17055" stroke-width="5" />`
        };

        const ShapeProperties = {
            Circle: { sides: 0, corners: 0, vertices: 0, desc: "A perfectly round shape with all points equidistant from the center. It has no straight sides or sharp corners." },
            Triangle: { sides: 3, corners: 3, vertices: 3, desc: "A three-sided polygon with inner angles summing to 180 degrees." },
            Square: { sides: 4, corners: 4, vertices: 4, desc: "A special quadrilateral featuring four perfectly equal sides and four 90-degree right angles." },
            Rectangle: { sides: 4, corners: 4, vertices: 4, desc: "A flat four-sided shape where parallel opposite sides are equal in length, containing four right angles." },
            Oval: { sides: 0, corners: 0, vertices: 0, desc: "An elongated circle looking much like an egg. It has zero straight lines and zero corners." },
            Pentagon: { sides: 5, corners: 5, vertices: 5, desc: "A geometric figure built out of 5 straight side segments and 5 internal corners." },
            Hexagon: { sides: 6, corners: 6, vertices: 6, desc: "A six-sided polygon structure. Honeycombs in nature utilize hexagons for perfect structural packing." },
            Heptagon: { sides: 7, corners: 7, vertices: 7, desc: "An uncommon polygon with exactly seven straight boundaries and seven corner nodes." },
            Octagon: { sides: 8, corners: 8, vertices: 8, desc: "An eight-sided mathematical polygon. Regular stop signs on streets are typical real-world octagons." },
            Nonagon: { sides: 9, corners: 9, vertices: 9, desc: "A shape constructed with nine individual sides and nine structural vertices." },
            Decagon: { sides: 10, corners: 10, vertices: 10, desc: "A polygon possessing ten flat outer bounds and ten internal corner configurations." },
            Semicircle: { sides: 2, corners: 2, vertices: 2, desc: "Exactly half of a circle, formed by a single straight diameter baseline and one curved outer arc line." }
        };

        function getSVGWrap(shapeKey) {
            return `<svg viewBox="0 0 200 200" preserveAspectRatio="xMidYMid meet">${ShapeRegistry[shapeKey]}</svg>`;
        }

        /*****************************************
         * DATA MATRIX ENGINE (50 STAGED QUESTIONS)
         *****************************************/
        const rawQuestionBank = [
            // SECTION A: IDENTIFY SHAPE (1-15)
            { type: 'A', shape: 'Circle', text: 'What is the name of this geometric shape?', ans: 'Circle', opts: ['Circle','Oval','Square','Triangle'] },
            { type: 'A', shape: 'Triangle', text: 'Identify the given colorful shape displaying three sides.', ans: 'Triangle', opts: ['Triangle','Hexagon','Square','Circle'] },
            { type: 'A', shape: 'Square', text: 'Which geometric name belongs to this shape with 4 equal sides?', ans: 'Square', opts: ['Square','Rectangle','Pentagon','Circle'] },
            { type: 'A', shape: 'Rectangle', text: 'What shape is displayed here with opposite parallel sides equal?', ans: 'Rectangle', opts: ['Rectangle','Square','Semicircle','Decagon'] },
            { type: 'A', shape: 'Oval', text: 'What is the name of this stretched, elongated round shape?', ans: 'Oval', opts: ['Oval','Circle','Triangle','Heptagon'] },
            { type: 'A', shape: 'Pentagon', text: 'Identify this flat polygon architecture that looks like a house frame.', ans: 'Pentagon', opts: ['Pentagon','Hexagon','Octagon','Triangle'] },
            { type: 'A', shape: 'Hexagon', text: 'What name is given to this shape resembling a honey-bee comb cell?', ans: 'Hexagon', opts: ['Hexagon','Heptagon','Octagon','Nonagon'] },
            { type: 'A', shape: 'Heptagon', text: 'Identify this polygon containing exactly 7 straight boundary lines.', ans: 'Heptagon', opts: ['Heptagon','Hexagon','Decagon','Octagon'] },
            { type: 'A', shape: 'Octagon', text: 'What shape matches this profile, identical to a standard road stop sign?', ans: 'Octagon', opts: ['Octagon','Nonagon','Decagon','Pentagon'] },
            { type: 'A', shape: 'Nonagon', text: 'Count the boundaries carefully. What is the name of this 9-sided polygon?', ans: 'Nonagon', opts: ['Nonagon','Octagon','Decagon','Heptagon'] },
            { type: 'A', shape: 'Decagon', text: 'Identify this complex multi-sided shape possessing 10 full vertices.', ans: 'Decagon', opts: ['Decagon','Nonagon','Heptagon','Semicircle'] },
            { type: 'A', shape: 'Semicircle', text: 'What is the correct mathematical name for this half-sliced circular object?', ans: 'Semicircle', opts: ['Semicircle','Circle','Oval','Triangle'] },
            { type: 'A', shape: 'Triangle', text: 'Identify this 3-cornered shape resting securely on its bottom flat base.', ans: 'Triangle', opts: ['Triangle','Square','Circle','Pentagon'] },
            { type: 'A', shape: 'Square', text: 'What 4-sided balanced shape is shown in the tracking viewer field?', ans: 'Square', opts: ['Square','Rectangle','Oval','Hexagon'] },
            { type: 'A', shape: 'Circle', text: 'Identify this simple continuous rounded boundary curve shape.', ans: 'Circle', opts: ['Circle','Oval','Semicircle','Triangle'] },

            // SECTION B: COUNT SIDES (16-25)
            { type: 'B', shape: 'Pentagon', text: 'How many straight outer lines or sides does a regular Pentagon have?', ans: '5', opts: ['5','4','6','3'] },
            { type: 'B', shape: 'Octagon', text: 'How many straight outer sides can you count on a standard Octagon sign?', ans: '8', opts: ['8','6','7','10'] },
            { type: 'B', shape: 'Triangle', text: 'How many straight perimeter sides are found on any basic Triangle?', ans: '3', opts: ['3','4','2','5'] },
            { type: 'B', shape: 'Hexagon', text: 'How many straight sides does a Hexagon have?', ans: '6', opts: ['6','5','7','8'] },
            { type: 'B', shape: 'Decagon', text: 'How many total sides are required to construct a full Decagon polygon?', ans: '10', opts: ['10','9','8','12'] },
            { type: 'B', shape: 'Square', text: 'How many straight sides are on a Square?', ans: '4', opts: ['4','3','5','6'] },
            { type: 'B', shape: 'Heptagon', text: 'How many straight boundary sides compose a Heptagon?', ans: '7', opts: ['7','6','8','9'] },
            { type: 'B', shape: 'Nonagon', text: 'How many flat perimeter sides are on a regular Nonagon shape?', ans: '9', opts: ['9','8','10','7'] },
            { type: 'B', shape: 'Circle', text: 'How many straight linear sides exist on a mathematically perfect Circle?', ans: '0', opts: ['0','1','2','Infinite'] },
            { type: 'B', shape: 'Semicircle', text: 'How many total lines (curved plus straight base) make up a Semicircle?', ans: '2', opts: ['2','1','3','0'] },

            // SECTION C: COUNT CORNERS / VERTICES (26-35)
            { type: 'C', shape: 'Hexagon', text: 'How many sharp corners (vertices) can you find around a Hexagon?', ans: '6', opts: ['6','5','7','4'] },
            { type: 'C', shape: 'Triangle', text: 'How many structural corners or vertices are found inside a Triangle?', ans: '3', opts: ['3','4','2','0'] },
            { type: 'C', shape: 'Oval', text: 'How many sharp corners or vertices does a smooth uniform Oval have?', ans: '0', opts: ['0','1','2','4'] },
            { type: 'C', shape: 'Pentagon', text: 'How many sharp point vertices form the structural tips of a Pentagon?', ans: '5', opts: ['5','6','4','3'] },
            { type: 'C', shape: 'Octagon', text: 'How many corner intersection vertices exist on an Octagon polygon?', ans: '8', opts: ['8','7','9','6'] },
            { type: 'C', shape: 'Square', text: 'How many 90-degree right angle corners does a standard Square have?', ans: '4', opts: ['4','3','5','0'] },
            { type: 'C', shape: 'Heptagon', text: 'What is the precise count of structural vertices inside a Heptagon?', ans: '7', opts: ['7','6','8','5'] },
            { type: 'C', shape: 'Decagon', text: 'How many total vertices exist on a full regular Decagon?', ans: '10', opts: ['10','12','8','9'] },
            { type: 'C', shape: 'Nonagon', text: 'How many vertex corner intersection points are on a regular Nonagon?', ans: '9', opts: ['9','10','8','7'] },
            { type: 'C', shape: 'Semicircle', text: 'How many distinct corner vertices exist where the curved arc meets the flat baseline on a Semicircle?', ans: '2', opts: ['2','0', '1','3'] },

            // SECTION D: PROPERTIES (36-45)
            { type: 'D', shape: 'Circle', text: 'Which of the following flat shapes has absolutely no straight lines and can roll easily?', ans: 'Circle', opts: ['Circle','Triangle','Square','Rectangle'] },
            { type: 'D', shape: 'Square', text: 'Which 2D shape possesses four completely equal straight sides and four right angles?', ans: 'Square', opts: ['Square','Rectangle','Triangle','Pentagon'] },
            { type: 'D', shape: 'Rectangle', text: 'Which shape has four sides where only the opposite parallel sides are equal in length?', ans: 'Rectangle', opts: ['Rectangle','Square','Hexagon','Oval'] },
            { type: 'D', shape: 'Triangle', text: 'If a 2D closed polygon has exactly three straight lines, it must be a:', ans: 'Triangle', opts: ['Triangle','Square','Circle','Pentagon'] },
            { type: 'D', shape: 'Pentagon', text: 'Which shape has more sides than a Square but fewer sides than a Hexagon?', ans: 'Pentagon', opts: ['Pentagon','Triangle','Heptagon','Octagon'] },
            { type: 'D', shape: 'Octagon', text: 'What shape features eight straight sides and looks like an intersection stop sign?', ans: 'Octagon', opts: ['Octagon','Hexagon','Nonagon','Decagon'] },
            { type: 'D', shape: 'Oval', text: 'Which shape looks like a flattened or stretched out circle, resembling an egg?', ans: 'Oval', opts: ['Oval','Circle','Semicircle','Triangle'] },
            { type: 'D', shape: 'Semicircle', text: 'Which shape is created by splitting a full circle perfectly in half?', ans: 'Semicircle', opts: ['Semicircle','Oval','Triangle','Hexagon'] },
            { type: 'D', shape: 'Decagon', text: 'Which of these polygons has the largest number of sides and vertices?', ans: 'Decagon', opts: ['Decagon','Nonagon','Octagon','Heptagon'] },
            { type: 'D', shape: 'Hexagon', text: 'Which shape matches the cells built by bees to construct honeycombs?', ans: 'Hexagon', opts: ['Hexagon','Pentagon','Octagon','Triangle'] },

            // SECTION E: MIXED CHALLENGE (46-50)
            { type: 'E', shape: null, text: 'Identify the odd shape out from the choices below based on side counts.', ans: 'Circle', opts: ['Circle','Triangle','Square','Pentagon'] },
            { type: 'E', shape: null, text: 'Which shape has fewer sides than a Hexagon?', ans: 'Triangle', opts: ['Triangle','Heptagon','Octagon','Nonagon'] },
            { type: 'E', shape: null, text: 'Choose the shape with the greatest number of individual sides.', ans: 'Decagon', opts: ['Decagon','Octagon','Hexagon','Pentagon'] },
            { type: 'E', shape: null, text: 'Which statement is perfectly true about a Square and a Rectangle?', ans: 'Both have 4 corners', opts: ['Both have 4 corners','Both have all sides equal','Both can roll in a straight line','Both have 3 vertices'] },
            { type: 'E', shape: null, text: 'If you combine two matching symmetrical semicircles along their flat lines, you get a:', ans: 'Circle', opts: ['Circle','Oval','Square','Triangle'] }
        ];

        let quizQuestions = [];
        let currentQuestionIndex = 0;
        let userScore = 0;
        let currentSelectedShape = "Circle";

        function shuffleArray(arr) {
            for (let i = arr.length - 1; i > 0; i--) {
                const j = Math.floor(Math.random() * (i + 1));
                [arr[i], arr[j]] = [arr[j], arr[i]];
            }
        }

        window.addEventListener('DOMContentLoaded', () => {
            generateFloatingBackground();
            initQuizData();
            renderQuestion();
            initExplorer();
            initSortingActivity();
        });

        function switchTab(tabId) {
            AudioEngine.click();
            document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
            document.querySelectorAll('.card').forEach(card => card.classList.remove('active'));
            
            event.target.classList.add('active');
            document.getElementById(tabId).classList.add('active');
        }

        function generateFloatingBackground() {
            const container = document.getElementById('bg-shapes-layer');
            const keys = Object.keys(ShapeRegistry);
            for(let i=0; i<12; i++) {
                let el = document.createElement('div');
                el.className = 'bg-shape';
                let randomShape = keys[Math.floor(Math.random() * keys.length)];
                el.innerHTML = ShapeRegistry[randomShape];
                el.style.width = Math.floor(Math.random()*40 + 40) + 'px';
                el.style.height = el.style.width;
                el.style.left = Math.floor(Math.random()*90) + 'vw';
                el.style.animationDelay = Math.floor(Math.random()*8) + 's';
                el.style.animationDuration = Math.floor(Math.random()*12 + 10) + 's';
                container.appendChild(el);
            }
        }

        function initQuizData() {
            quizQuestions = JSON.parse(JSON.stringify(rawQuestionBank));
            shuffleArray(quizQuestions);
            quizQuestions.forEach(q => {
                shuffleArray(q.opts);
            });
            currentQuestionIndex = 0;
            userScore = 0;
        }

        function renderQuestion() {
            const q = quizQuestions[currentQuestionIndex];
            
            document.getElementById('question-counter').innerText = `Question: ${currentQuestionIndex + 1} / ${quizQuestions.length}`;
            document.getElementById('score-counter').innerText = `Score: ${userScore}`;
            const progressPercent = ((currentQuestionIndex) / quizQuestions.length) * 100;
            document.getElementById('quiz-progress').style.width = `${progressPercent}%`;

            document.getElementById('question-text').innerText = q.text;

            const visualBox = document.getElementById('question-visual');
            visualBox.innerHTML = "";
            if (q.shape && ShapeRegistry[q.shape]) {
                visualBox.innerHTML = getSVGWrap(q.shape);
                visualBox.style.display = "flex";
            } else {
                visualBox.innerHTML = `<span style="font-size:2.5rem;">❓🟩🔺🔵</span>`;
            }

            const optionsBox = document.getElementById('options-container');
            optionsBox.innerHTML = "";
            
            const feedbackPanel = document.getElementById('feedback-panel');
            feedbackPanel.className = "feedback-box";
            feedbackPanel.innerHTML = "";

            q.opts.forEach(optionText => {
                const btn = document.createElement('button');
                btn.className = 'option-btn';
                btn.innerText = optionText;
                btn.onclick = () => evaluateUserAnswer(btn, optionText, q.ans);
                optionsBox.appendChild(btn);
            });

            document.getElementById('prev-btn').disabled = (currentQuestionIndex === 0);
            document.getElementById('next-btn').innerText = "Skip Question";
        }

        function evaluateUserAnswer(selectedBtn, selectedValue, correctValue) {
            const isCorrect = (selectedValue === correctValue);
            const feedbackPanel = document.getElementById('feedback-panel');
            const q = quizQuestions[currentQuestionIndex];

            document.querySelectorAll('.option-btn').forEach(b => {
                b.classList.add('disabled');
                if(b.innerText === correctValue) {
                    b.classList.add('correct');
                }
            });

            if (isCorrect) {
                userScore++;
                selectedBtn.classList.add('correct');
                feedbackPanel.className = "feedback-box correct";
                feedbackPanel.innerHTML = `<strong>✅ Correct Answer!</strong>`;
                AudioEngine.correct();
            } else {
                selectedBtn.classList.add('wrong');
                feedbackPanel.className = "feedback-box wrong";
                feedbackPanel.innerHTML = `<strong>❌ Incorrect.</strong> The correct choice is <strong>${correctValue}</strong>.`;
                AudioEngine.wrong();
            }

            let propertiesBlurb = "";
            if(q.shape && ShapeProperties[q.shape]) {
                const prop = ShapeProperties[q.shape];
                propertiesBlurb = `<br><span style="display:block; margin-top:8px; font-size:0.95rem;">💡 <strong>${q.shape} Properties:</strong> It has <strong>${prop.sides} sides</strong> and <strong>${prop.vertices} vertices/corners</strong>.</span>`;
            }
            feedbackPanel.innerHTML += propertiesBlurb;

            document.getElementById('score-counter').innerText = `Score: ${userScore}`;
            document.getElementById('next-btn').innerText = "Next Question ➡️";
        }

        function nextQuestion() {
            AudioEngine.click();
            if (currentQuestionIndex < quizQuestions.length - 1) {
                currentQuestionIndex++;
                renderQuestion();
            } else {
                showQuizResultsSummary();
            }
        }

        function prevQuestion() {
            AudioEngine.click();
            if (currentQuestionIndex > 0) {
                currentQuestionIndex--;
                renderQuestion();
            }
        }

        function showQuizResultsSummary() {
            document.getElementById('quiz-playground').style.display = 'none';
            const resultsDiv = document.getElementById('quiz-results');
            resultsDiv.style.display = 'block';

            const percentage = Math.round((userScore / quizQuestions.length) * 100);
            document.getElementById('final-score-text').innerText = `Your Score: ${userScore} / ${quizQuestions.length} (${percentage}%)`;

            let badge = "📚";
            let title = "Keep Practising";
            if (percentage >= 90) { badge = "🏆"; title = "Shape Master"; }
            else if (percentage >= 70) { badge = "🌟"; title = "Geometry Explorer"; }
            else if (percentage >= 50) { badge = "👍"; title = "Good Learner"; }

            document.getElementById('result-badge-icon').innerText = badge;
            document.getElementById('result-badge-title').innerText = title;

            AudioEngine.badge();
            if(percentage >= 70) {
                triggerConfettiCelebration();
            }
        }

        function restartQuiz() {
            AudioEngine.click();
            initQuizData();
            document.getElementById('quiz-results').style.display = 'none';
            document.getElementById('quiz-playground').style.display = 'block';
            renderQuestion();
        }

        function showCertificateView() {
            AudioEngine.click();
            const percentage = Math.round((userScore / quizQuestions.length) * 100);
            document.getElementById('cert-score-metric').innerText = `Score Attained: ${percentage}% (${userScore}/${quizQuestions.length} Questions Correct)`;
            document.getElementById('certificate-printout-area').style.display = 'block';
            document.getElementById('certificate-printout-area').scrollIntoView({ behavior: 'smooth' });
        }

        /*****************************************
         * CONFIGURABLE INTERACTIVE EXPLORER
         *****************************************/
        function initExplorer() {
            const menu = document.getElementById('explorer-menu');
            menu.innerHTML = "";
            Object.keys(ShapeRegistry).forEach((shapeName, i) => {
                const btn = document.createElement('button');
                btn.className = `shape-sidebar-btn ${i===0?'active':''}`;
                btn.innerText = shapeName;
                btn.onclick = () => selectExplorerShape(shapeName, btn);
                menu.appendChild(btn);
            });
            loadExplorerShapeData();
        }

        function selectExplorerShape(name, element) {
            AudioEngine.click();
            document.querySelectorAll('.shape-sidebar-btn').forEach(b => b.classList.remove('active'));
            element.classList.add('active');
            currentSelectedShape = name;
            loadExplorerShapeData();
        }

        function loadExplorerShapeData() {
            const container = document.getElementById('explorer-svg-container');
            container.innerHTML = getSVGWrap(currentSelectedShape);
            
            const prop = ShapeProperties[currentSelectedShape];
            const infoBox = document.getElementById('explorer-info');
            infoBox.innerHTML = `
                <h3 style="margin-bottom: 5px; color: var(--primary);">${currentSelectedShape}</h3>
                <p><strong>📐 Sides:</strong> ${prop.sides} &nbsp;|&nbsp; <strong>📍 Corners / Vertices:</strong> ${prop.vertices}</p>
                <p style="margin-top: 6px; font-size: 0.9rem; color: #555; line-height:1.4;">${prop.desc}</p>
            `;
            
            document.getElementById('exp-scale').value = 1;
            document.getElementById('exp-rotate').value = 0;
            updateExplorerTransform();
        }

        function updateExplorerTransform() {
            const scale = document.getElementById('exp-scale').value;
            const rotate = document.getElementById('exp-rotate').value;
            const svg = document.querySelector('#explorer-svg-container svg');
            if(svg) {
                svg.style.transform = `scale(${scale}) rotate(${rotate}deg)`;
            }
        }

        /*****************************************
         * DRAG AND DROP GEOMETRY SORTER ENGINE
         *****************************************/
        const sortingItemsData = [
            { id: 's1', name: 'Circle', criteria: 'no-sides' },
            { id: 's2', name: 'Triangle', criteria: 'three-sides' },
            { id: 's3', name: 'Square', criteria: 'four-sides' },
            { id: 's4', name: 'Rectangle', criteria: 'four-sides' },
            { id: 's5', name: 'Oval', criteria: 'no-sides' },
            { id: 's6', name: 'Pentagon', criteria: 'more-sides' },
            { id: 's7', name: 'Hexagon', criteria: 'more-sides' },
            { id: 's8', name: 'Octagon', criteria: 'more-sides' }
        ];

        function initSortingActivity() {
            const pool = document.getElementById('shapes-drag-pool');
            pool.innerHTML = "";
            
            document.querySelectorAll('.bin').forEach(bin => {
                const header = bin.querySelector('h3');
                bin.innerHTML = "";
                bin.appendChild(header);
            });

            let workingSet = [...sortingItemsData];
            shuffleArray(workingSet);

            workingSet.forEach(item => {
                const div = document.createElement('div');
                div.className = 'draggable-shape';
                div.id = item.id;
                div.draggable = true;
                div.setAttribute('data-criteria', item.criteria);
                div.ondragstart = handleDragStart;
                
                div.innerHTML = `${getSVGWrap(item.name)} <span>${item.name}</span>`;
                pool.appendChild(div);
            });
        }

        function handleDragStart(e) {
            e.dataTransfer.setData('text/plain', e.target.id);
            AudioEngine.click();
        }

        function allowDrop(e) {
            e.preventDefault();
            e.currentTarget.classList.add('drag-over');
        }

        function dragLeave(e) {
            e.currentTarget.classList.remove('drag-over');
        }

        function handleDrop(e) {
            e.preventDefault();
            const bin = e.currentTarget;
            bin.classList.remove('drag-over');
            
            const elementId = e.dataTransfer.getData('text/plain');
            const draggedEl = document.getElementById(elementId);
            if (!draggedEl) return;

            const targetCriteria = bin.getAttribute('data-criteria');
            const elementCriteria = draggedEl.getAttribute('data-criteria');

            if (targetCriteria === elementCriteria) {
                bin.appendChild(draggedEl);
                draggedEl.draggable = false;
                draggedEl.style.cursor = 'default';
                draggedEl.style.borderColor = 'var(--success)';
                AudioEngine.correct();
                
                checkSortingCompletion();
            } else {
                AudioEngine.wrong();
                draggedEl.style.transform = 'skewX(10deg)';
                setTimeout(() => draggedEl.style.transform = '', 200);
            }
        }

        function checkSortingCompletion() {
            const pool = document.getElementById('shapes-drag-pool');
            if(pool.children.length === 0) {
                triggerConfettiCelebration();
                AudioEngine.badge();
            }
        }

        function resetSortingActivity() {
            AudioEngine.click();
            initSortingActivity();
        }

        /*****************************************
         * CONFETTI FX SYSTEM GENERATOR
         *****************************************/
        function triggerConfettiCelebration() {
            const canvas = document.getElementById('confetti-canvas');
            const ctx = canvas.getContext('2d');
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
            canvas.style.display = 'block';

            let pieces = [];
            for (let i = 0; i < 120; i++) {
                pieces.push({
                    x: Math.random() * canvas.width,
                    y: Math.random() * canvas.height - canvas.height,
                    r: Math.random() * 6 + 4,
                    d: Math.random() * canvas.height,
                    color: `hsl(${Math.random() * 360}, 90%, 60%)`,
                    tilt: Math.random() * 10 - 5,
                    tiltAngleIncremental: Math.random() * 0.07 + 0.02,
                    tiltAngle: 0
                });
            }

            let animationFrameId;
            let startTimestamp = Date.now();

            function drawConfetti() {
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                
                pieces.forEach((p, index) => {
                    p.tiltAngle += p.tiltAngleIncremental;
                    p.y += (Math.cos(p.d) + 3 + p.r / 2) / 2;
                    p.x += Math.sin(p.tiltAngle);
                    p.tilt = Math.sin(p.tiltAngle - index / 3) * 15;

                    ctx.beginPath();
                    ctx.lineWidth = p.r;
                    ctx.strokeStyle = p.color;
                    ctx.moveTo(p.x + p.tilt + p.r / 2, p.y);
                    ctx.lineTo(p.x + p.tilt, p.y + p.tilt + p.r / 2);
                    ctx.stroke();
                });

                if (Date.now() - startTimestamp < 4000) {
                    animationFrameId = requestAnimationFrame(drawConfetti);
                } else {
                    ctx.clearRect(0, 0, canvas.width, canvas.height);
                    canvas.style.display = 'none';
                    cancelAnimationFrame(animationFrameId);
                }
            }
            drawConfetti();
        }
    </script>
